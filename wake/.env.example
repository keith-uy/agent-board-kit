# ntfy topic the n8n workflow publishes to and this Mac subscribes to.
# Pick a LONG random suffix so the topic is unguessable. No task data flows here,
# only a content-free wake ping, so a public ntfy.sh topic is acceptable.
# For extra safety you can self-host ntfy or use an access token / reserved topic.
NTFY_URL=https://ntfy.sh/winflow-clickup-CHANGE-ME-to-a-long-random-string

# --- register_webhook.py only (creating the ClickUp webhook) ---
# ClickUp personal token (pk_...). Same value as worker/.env CLICKUP_TOKEN.
CLICKUP_TOKEN=
# Your ClickUp workspace (team) id. Find it in any ClickUp URL: app.clickup.com/{team_id}/...
CLICKUP_TEAM_ID=
# The list the webhook is scoped to. Same value as worker/.env CLICKUP_LIST_ID.
CLICKUP_LIST_ID=
# The public n8n Production webhook URL that ClickUp will POST to.
N8N_WEBHOOK_URL=
