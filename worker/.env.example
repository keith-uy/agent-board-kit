# Copy to .env and fill in. .env is gitignored; never commit real values.

# --- ClickUp (required) ---
CLICKUP_TOKEN=pk_your_personal_token_here
CLICKUP_LIST_ID=your_list_id_here

# --- Auth mode ---
# subscription = run on this machine's Claude login ($0 marginal, draws your plan).
#                Requires a prior `claude login` (or CLAUDE_CODE_OAUTH_TOKEN) and
#                ANTHROPIC_API_KEY UNSET.
# api          = run on an Anthropic API key (billed per token, no login needed).
AUTH_MODE=subscription
# Only used when AUTH_MODE=api:
ANTHROPIC_API_KEY=

# --- Tuning (optional, sensible defaults shown) ---
POLL_SECONDS=90
MAX_PER_CYCLE=3
STALE_MINUTES=120
CLAUDE_MODEL=claude-opus-4-8
MAX_TURNS=40
TASK_TIMEOUT_SECONDS=1500
EVAL_TIMEOUT_SECONDS=300
PUBLISH_SAFETY=on

# Where claude runs tasks (file-editing tasks land here). Defaults to worker/workspace.
WORK_DIR=
# Buyer knowledge base folder. Defaults to ../knowledge-base.
KB_DIR=

# acceptEdits (default, safer) or bypassPermissions (full autonomy, incl. Bash)
PERMISSION_MODE=auto
