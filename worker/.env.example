# Copy to .env and fill in. .env is gitignored; never commit real values.

# --- ClickUp (required) ---
CLICKUP_TOKEN=pk_your_personal_token_here
CLICKUP_LIST_ID=your_list_id_here

# --- Auth mode (pick your deployment — see DEPLOYMENT.md) ---
# subscription = run on THIS Mac's Claude login. $0 marginal (draws your plan), but
#                only works while the Mac is awake. Requires a prior `claude login`
#                and ANTHROPIC_API_KEY UNSET. Pair with PERMISSION_MODE=auto.
# api          = run on an Anthropic API key. Billed per token, but can run on an
#                always-on server 24/7 (no "is my Mac awake?"). Pair with
#                PERMISSION_MODE=bypassPermissions on an isolated server/VM.
AUTH_MODE=subscription
# Only used when AUTH_MODE=api:
ANTHROPIC_API_KEY=

# --- Tuning (optional, sensible defaults shown) ---
# Subscription+wake-webhook: 600 (poll is just a backstop). API+server: 60 (poll often, cheap).
POLL_SECONDS=600
MAX_PER_CYCLE=3
STALE_MINUTES=120
CLAUDE_MODEL=claude-opus-4-8
MAX_TURNS=40
TASK_TIMEOUT_SECONDS=1500
EVAL_TIMEOUT_SECONDS=300
PUBLISH_SAFETY=on

# Where claude runs tasks (file-editing tasks land here). Defaults to worker/workspace.
WORK_DIR=
# Buyer knowledge base folder. Defaults to ../knowledge-base.
KB_DIR=

# Permission mode. `auto` = a safety classifier reviews each action (needs a Claude
# subscription plan; use with AUTH_MODE=subscription). `bypassPermissions` = no prompts
# (use only on an isolated server/VM; pair with AUTH_MODE=api). Either way the deny-list
# at worker/workspace/.claude/settings.json hard-blocks destructive commands in EVERY mode.
PERMISSION_MODE=auto
